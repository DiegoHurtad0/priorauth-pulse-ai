# PriorAuth Pulse — Environment Variables
# Copy this file to backend/.env and fill in your actual values.
# For Docker Compose, place this file at the root as .env

# ── TinyFish Web Agent ────────────────────────────────────────────────────────
# Required for live PA checking. Get yours at: https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=sk-tinyfish-your-key-here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# ── Claude AI (Appeal Letters) ────────────────────────────────────────────────
# Required for AI-generated denial appeal letters via Claude Opus
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── AgentOps Monitoring (Optional) ───────────────────────────────────────────
# Enables session replay and agent run tracing dashboard
# Get yours at: https://agentops.ai
AGENTOPS_API_KEY=your_agentops_api_key_here

# ── Slack Notifications (Optional) ───────────────────────────────────────────
# Sends PA status change alerts to a Slack channel
# Create via Composio → Slack → Incoming Webhook
COMPOSIO_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── Frontend ──────────────────────────────────────────────────────────────────
# Backend API URL for Next.js frontend (default: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false
