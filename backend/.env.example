# PriorAuth Pulse — Backend Environment Variables
# Copy this file to .env and fill in your actual values.

# TinyFish Web Agent API key
# Get yours at: https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=sk-tinyfish-your-key-here

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# AgentOps monitoring (optional — metrics/tracing dashboard)
# Get yours at: https://agentops.ai
AGENTOPS_API_KEY=your_agentops_api_key_here

# Composio Slack webhook URL for PA status change alerts
# Create via Composio → Slack → Incoming Webhook
COMPOSIO_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Server port (default: 8000)
PORT=8000
